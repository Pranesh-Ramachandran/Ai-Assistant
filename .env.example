# JARVIS AI Assistant — API Keys
# NEVER commit this file. It is listed in .gitignore.
# Copy this to .env and fill in your real keys.

# ── AI API Keys ───────────────────────────────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Flask ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
FLASK_PORT=5000
FLASK_DEBUG=false
# Bind host — keep 127.0.0.1 for phone-local use; set to 0.0.0.0 only behind a firewall
FLASK_HOST=127.0.0.1
# TLS (optional but recommended on phone) — set paths to your cert/key files
# JARVIS_SSL_CERT=cert.pem
# JARVIS_SSL_KEY=key.pem
# JARVIS_HTTPS=true

# ── STT ───────────────────────────────────────────────────────
# Options: auto | google | azure | vosk
JARVIS_STT_ENGINE=google

# Azure STT (optional — only if you have a key)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus

# ── TTS ───────────────────────────────────────────────────────
# Options: hq (edge-tts) | fast (pyttsx3)
JARVIS_TTS_MODE=fast

# ── AI routing ────────────────────────────────────────────────
# Options: hybrid | groq | gemini | offline
JARVIS_AI_MODE=hybrid

# ── Vosk offline STT model path ───────────────────────────────
VOSK_MODEL_PATH=models/vosk-model-small-en-us-0.15
